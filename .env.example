# ローカル実行 / GitHub Secrets に設定する値
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account", ... 全文をそのまま ...}'
SPREADSHEET_ID=スプレッドシートのID（URLの /d/ と /edit の間）
TZ_NAME=Asia/Tokyo
# 1アカ1日上限（ローカル実行用）。GitHub Actions ではリポジトリ Variable
# vars.MAX_POSTS_PER_DAY が単一の真実（未設定なら 50。post.yml 参照）。
MAX_POSTS_PER_DAY=50
# DRY_RUN=1   # 検証時のみ。シートを一切書き換えず、公開対象の検出と疎通確認のみ行う
